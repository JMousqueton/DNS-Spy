# DNS Spy — Environment Configuration
# Copy this file to .env and adjust the values for your environment.

# Flask secret key — change this to a long random string in production
SECRET_KEY=change-me-to-a-random-secret

# Enable debug mode (also disables SSL verification for MITM proxy support)
DEBUG=false

# Cache TTL in seconds (default: 5 minutes)
CACHE_TTL=300

# Rate limiting — max requests per window per IP
RATE_LIMIT_REQUESTS=10
RATE_LIMIT_WINDOW=60

# Number of subdomains to brute-force (from built-in wordlist)
SUBDOMAIN_WORDLIST_SIZE=50

# Default HTTP request timeout in seconds
REQUEST_TIMEOUT=10

# Screenshot capture via Playwright
SCREENSHOT_ENABLED=true
SCREENSHOT_TIMEOUT=15

# SSL certificate verification for outbound requests
# Automatically disabled when DEBUG=true (useful behind MITM proxies like Zscaler)
# Set explicitly to override: true or false
# VERIFY_SSL=true
